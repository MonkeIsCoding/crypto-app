rules_version = '2';

// Architecture note: RN/iOS clients never talk to Firestore directly — they
// only use the Firebase Auth SDK for sessions. All Firestore reads/writes go
// through the Express backend via firebase-admin, which runs with a service
// account and bypasses these rules entirely. So client-facing access here is
// deliberately locked down to nothing; this file exists to make that
// intentional rather than relying on Firestore's production-mode default.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
