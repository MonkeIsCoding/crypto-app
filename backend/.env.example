PORT=3000

# Firebase Admin SDK service account (download from Firebase console)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# CoinGecko
COINGECKO_API_BASE=https://api.coingecko.com/api/v3

# Comma-separated coin ids cached daily (CoinGecko ids, e.g. bitcoin,ethereum)
TRACKED_COIN_IDS=bitcoin,ethereum,solana,cardano,ripple,dogecoin,polkadot,litecoin,chainlink,avalanche-2

# Cron schedule (default: once daily at 03:00)
CRON_SCHEDULE=0 3 * * *
